{
  "name": "stb-chatbot",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c red,cyan \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:reset": "npm run db:reset --prefix backend",
    "setup": "npm install --prefix backend && npm install --prefix frontend && npm run db:push --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.39.0"
  }
}
